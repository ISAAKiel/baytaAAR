Package: baytaAAR
Type: Package
Title: Bayesian Transition Analysis with Markov Chain Monte Carlo
Version: 1.0.2
Authors@R: c(person(given = "Nils", family = "Müller-Scheeßel",
                      email = "nils.mueller-scheessel@ufg.uni-kiel.de",
                      role = c("aut", "cre", "cph"),
                      comment = c(ORCID = "0000-0001-7992-8722")),
